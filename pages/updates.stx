              @else
                <button class="btn btn-sm" x-show="!isUpdating('{{ pkg.name }}')" onclick="doUpdate('{{ esc(pkg.name) }}', 'formula')">Update</button>
                <span x-show="isUpdating('{{ pkg.name }}')" class="dim" style="font-size: 11px;">Updating...</span>
              @endif
            </td>
          </tr>
        @endforeach
      </tbody>
    </table>
  </div>
@endif

</div>
</div>

<script data-stx-scoped>
function _api(endpoint, data) {
  return fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data || {}) }).then(function(r) { return r.json(); });
}

function _exec(stmt) {
  var el = document.querySelector('[data-stx-scope]');
  if (el && el.__stx_execute) el.__stx_execute(stmt);
}

function doUpdate(name, type) {
  var key = type === 'cask' ? 'cask:' + name : name;
  _exec("updating['" + key + "'] = true");
  _api('/api/brew-update', { name: name, type: type }).then(function(r) {
    _exec("delete updating['" + key + "']");
    if (r.success) {
      _exec("updated['" + key + "'] = true");
      _exec("toast('" + name.replace(/'/g, "\\'") + " updated to " + (r.version || 'latest').replace(/'/g, "\\'") + "', 'success')");
    } else {
      _exec("toast('Failed to update " + name.replace(/'/g, "\\'") + ": " + (r.error || 'Unknown').replace(/'/g, "\\'") + "', 'error')");
    }
  });
}

function doUpdateSelected() {
  var scope = document.querySelector('[data-stx-scope]');
  if (!scope || !scope.__stx_state) return;
  var items = scope.__stx_state.selected || [];
  if (items.length === 0) return;
  if (!confirm('Update ' + items.length + ' packages?')) return;
  items.forEach(function(key) {
    var isCask = key.startsWith('cask:');
    var name = isCask ? key.slice(5) : key;
    doUpdate(name, isCask ? 'cask' : 'formula');
  });
}

function doUpdateAll() {
  if (!confirm('Update all outdated packages? This may take a while.')) return;
  _exec("toast('Running brew upgrade...', 'info')");
  _api('/api/brew-update-all', {}).then(function(r) {
    if (r.success) {
      _exec("toast('All packages updated! Refresh to see changes.', 'success')");
    } else {
      _exec("toast('Update failed: " + (r.error || 'Unknown').replace(/'/g, "\\'") + "', 'error')");
    }
  });
}
</script>
@endsection
