              <span x-show="isUpdating('cask:{{ pkg.name }}')" class="dim" style="font-size: 11px;">Updating...</span>
            </td>
          </tr>
        @endforeach
        @foreach(brewFormulae as pkg)
          <tr x-show="!isUpdated('{{ pkg.name }}')">
            <td><input type="checkbox" class="check" :checked="isOn('{{ pkg.name }}')" @click="toggle('{{ pkg.name }}')" /></td>
            <td>
              <span class="item-name">{{ pkg.name }}</span>
              @if(pkg.pinned)
                <span class="badge badge-gray" style="margin-left: 4px;">pinned</span>
              @endif
            </td>
