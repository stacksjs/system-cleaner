<script server>
const { getSystemInfoSync, execSync, escapeHtml } = require('@system-cleaner/core')

const sysInfo = getSystemInfoSync()
const username = sysInfo.username
const macosVersion = sysInfo.macosVersion

function safeExec(cmd, fallback) {
  try { return execSync(cmd, { timeout: 30000 }) }
  catch { return fallback || '' }
}

function esc(str) { return escapeHtml(str || '') }

// Homebrew outdated packages
const brewFormulae = []
const brewCasks = []
try {
  const raw = safeExec('brew outdated --json 2>/dev/null')
  if (raw) {
    const data = JSON.parse(raw)
    for (const f of (data.formulae || [])) {
      brewFormulae.push({
        name: f.name,
        current: (f.installed_versions || [])[0] || '?',
        latest: f.current_version || '?',
        pinned: f.pinned || false,
      })
    }
    for (const c of (data.casks || [])) {
      brewCasks.push({
        name: c.name,
        current: (c.installed_versions || [])[0]?.split(',')[0] || '?',
        latest: c.current_version?.split(',')[0] || '?',
      })
    }
  }
} catch {}

const totalOutdated = brewFormulae.length + brewCasks.length
</script>

@layout('app')

@section('username'){{ username }}@endsection
@section('macos')macOS {{ macosVersion }}@endsection

@section('body')
<div x-data="{
  selected: [],
  updating: {},
  updated: {},
  toasts: [],
  toastId: 0,

  toggle(name) { const i = this.selected.indexOf(name); if (i === -1) this.selected.push(name); else this.selected.splice(i, 1); },
  isOn(name) { return this.selected.includes(name); },
  isUpdating(name) { return !!this.updating[name]; },
  isUpdated(name) { return !!this.updated[name]; },
  allOn(names) { if (names.every(n => this.selected.includes(n))) this.selected = this.selected.filter(n => !names.includes(n)); else names.forEach(n => { if (!this.selected.includes(n)) this.selected.push(n); }); },

  toast(msg, type) {
    const id = ++this.toastId;
    this.toasts = [...this.toasts, { id, msg, type: type || 'info' }];
    setTimeout(() => { this.toasts = this.toasts.filter(t => t.id !== id); }, 5000);
  }
}">

<div class="toast-area">
  @for(let i = 0; i < 5; i++)
    <div class="toast" x-show="toasts[{{ i }}]" x-text="toasts[{{ i }}] ? (toasts[{{ i }}].type === 'success' ? '✓' : toasts[{{ i }}].type === 'error' ? '✕' : '⚠') + ' ' + toasts[{{ i }}].msg : ''"></div>
  @endfor
</div>

